# ==========================================
# 1. BACKEND (Python)
# ==========================================
# Wirtualne środowiska
backend/venv/
backend/env/
venv/

# Pliki tymczasowe Pythona
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Ignoruj CAŁY nowy folder z danymi (SQLite i pobrane JSON-y)
backend/data/

# ==========================================
# 2. FRONTEND (Vue.js / Vite)
# ==========================================
# Paczki Node.js
**/node_modules/

# Gotowa aplikacja (build)
**/dist/

# Logi błędów
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 3. BEZPIECZEŃSTWO I SEKRETY (KRYTYCZNE!)
# ==========================================
# Zmienne środowiskowe
**/.env
**/.env.local
**/.env.*.local

# Klucz szyfrujący AES (Prywatność haseł lokalnych)
**/.secret.key

